{
  "name": "@aioson/auth-sdk",
  "version": "0.2.0",
  "description": "Cliente TypeScript canônico para o aioson-auth — core + adapters React/Express",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express/index.js",
      "require": "./dist/express/index.cjs"
    },
    "./embedded": {
      "types": "./dist/embedded/index.d.ts",
      "import": "./dist/embedded/index.js",
      "require": "./dist/embedded/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "bench": "node bench/perf.mjs",
    "test:embedded": "node test/embedded-smoke.mjs",
    "test:core": "node test/core-flows.test.mjs",
    "test:next": "node test/next-adapter.test.mjs",
    "test": "node test/embedded-smoke.mjs && node test/core-flows.test.mjs && node test/next-adapter.test.mjs"
  },
  "keywords": [
    "aioson",
    "auth",
    "rbac",
    "jwt",
    "sdk"
  ],
  "author": "AIOSON",
  "license": "MIT",
  "peerDependencies": {
    "bcryptjs": "^3.0.3",
    "express": ">=4.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "bcryptjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "next": "^14.2.35",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
