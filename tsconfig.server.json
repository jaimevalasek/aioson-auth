{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist/server",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/server.ts",
    "src/app.ts",
    "src/lib/**/*",
    "src/actions/**/*",
    "src/routes/**/*",
    "src/services/**/*",
    "src/middleware/**/*"
  ],
  "exclude": ["node_modules", "dist", "src/client"]
}
